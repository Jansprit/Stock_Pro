# ===== AI 報告（中轉站 OpenAI 相容 /v1/chat/completions）=====
# 變數名刻意用 AI_RELAY_* 而非 ANTHROPIC_*，避免與 Claude Code shell env 衝突
AI_RELAY_BASE_URL=https://your-ai-relay.example.com
AI_RELAY_MODEL=MiniMax-M2.7
AI_RELAY_API_KEY=


# ========== 股票資料源（聰明路由）==========
# Yahoo Finance 自動走 v8/finance/chart（已驗證可用），無需 key

# Finnhub — 美股即時報價、新聞、搜尋、估值指標
# 免費額度：60 次/分鐘
# 申請：https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage — 詳細基本面、年度財報、技術指標
# 免費額度：25 次/天、上限 5 次/分鐘（嚴格）
# 申請：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Twelve Data — K 線、技術指標、報價、貨幣
# 免費額度：800 credits/天、8 credits/分鐘
# 申請：https://twelvedata.com/register
TWELVE_DATA_API_KEY=


# ========== 估值面板（公允價值 + 分析師目標價）==========

# FRED API — 抓 10 年期美債殖利率作為 WACC 的無風險利率（rf）
# 沒設 key 時自動 fallback 寫死常數 4.5%
# 免費註冊：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# SEC EDGAR User-Agent（per fair access policy，必須填聯絡 email）
# Yahoo v10 / SEC 都會讀這個
SEC_USER_AGENT=research@example.com

# 估值模型權重（選填，預設值見 lib/valuation/constants.ts）
# VALUATION_W_DCF=0.30
# VALUATION_W_DDM=0.15
# VALUATION_W_PE=0.25
# VALUATION_W_PS=0.15
# VALUATION_W_EVEBITDA=0.15

# WACC 參數（選填）
# VALUATION_ERP=0.055
# VALUATION_SAFE_GDP=0.025
# VALUATION_SAFE_PE=15
# VALUATION_DCF_YEARS=5